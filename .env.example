# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
# Anti-leech: comma-separated list of guild IDs this bot is allowed to run
# in. Anything else, the bot leaves on join. Defaults to DISCORD_GUILD_ID if
# unset. Useful for self-hosters: prevents your token-and-config copy of
# the bot from being usable in someone else's server.
ALLOWED_GUILD_IDS=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Minecraft server (mineflayer joins the MAIN server) ---
MC_SERVER_HOST=
MC_SERVER_PORT=25565
MC_BOT_USERNAME=
# microsoft | offline   (mojang accounts are deprecated upstream)
MC_BOT_AUTH=microsoft
# "Home" coords the bot returns to when idle (optional; leave blank to skip)
MC_BOT_HOME_X=
MC_BOT_HOME_Y=
MC_BOT_HOME_Z=

# --- RCON (against the main server) ---
RCON_HOST=
RCON_PORT=25575
RCON_PASSWORD=

# --- User-facing MC server addresses (shown in DMs / kick messages) ---
VERIFY_SERVER_ADDRESS=verify.example.com:25565
MAIN_SERVER_ADDRESS=play.example.com:25565
# MCXboxBroadcast gamertag Bedrock players add as a friend then "Join".
# Leave blank until you've set up MCXboxBroadcast on the verify server.
# When blank, the DM tells Bedrock players support is being set up.
BEDROCK_FRIEND_NAME=

# --- HTTP API the verify-mod calls ---
# MOD_API_SECRET must match the apiSecret in config/verify-mod.json on the MC server.
# Generate a random 32+ char string. Treat as a secret.
MOD_API_PORT=3001
MOD_API_SECRET=
# Optional: GitHub webhook HMAC secret. Set the same value in your repo
# Settings -> Webhooks -> Add webhook -> Secret. If unset, the /github
# webhook endpoint refuses everything.
GITHUB_WEBHOOK_SECRET=

# --- Channel + role IDs ---
# Linking
VERIFY_CHANNEL_ID=
# Discord role assigned when a user's account is linked. Used to unlock
# access to Discord channels for verified members. This is a Discord-side
# gate only — it does NOT affect Minecraft server access.
VERIFIED_ROLE_ID=
# Sponsor
SPONSOR_CHANNEL_ID=
TRUSTED_ROLE_ID=
SPONSEE_ROLE_ID=
ADMIN_ROLE_ID=
# Channel where the admin panel lives. Lock View Channel to ADMIN_ROLE_ID only.
ADMIN_PANEL_CHANNEL_ID=
# Request-a-sponsor
REQUEST_SPONSOR_CHANNEL_ID=
SPONSOR_REQUESTS_CHANNEL_ID=
# Bounty (phase 3)
BOUNTY_CHANNEL_ID=
BOUNTY_ROLE_ID=
# Optional: critical errors get posted here
ADMIN_LOG_CHANNEL_ID=
# Modmail: per-user threads get created here when someone DMs or @-mentions
# the bot. Admin replies in those threads relay back to the user as a DM.
# Leave blank to disable modmail.
MODMAIL_CHANNEL_ID=

# --- LuckPerms (phase 2 sponsor system) ---
# Group names the sponsor system will grant via RCON. Unused until phase 2.
LP_SPONSEE_GROUP=sponsee
LP_TRUSTED_GROUP=trusted
